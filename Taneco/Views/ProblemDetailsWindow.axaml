<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Taneco.ViewModels"
        x:Class="Taneco.Views.ProblemDetailsWindow"
        x:DataType="vm:ProblemDetailsViewModel"
        Title="Детали проблемы"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="15">

        <!-- Информация о проблеме -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="{Binding Problem.PipelineName}" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="{Binding Problem.Type}" FontSize="12" Foreground="{StaticResource WarningBrush}"/>
                <TextBlock Text="{Binding Problem.Description}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                           TextWrapping="Wrap" Margin="0,10,0,0"/>
                <Grid ColumnDefinitions="Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Text="Отклонение:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Problem.MeasuredValue} / {Binding Problem.ThresholdValue}" FontSize="14" FontWeight="Bold" 
                               Foreground="{StaticResource DangerBrush}" Margin="10,0,0,0"/>
                </Grid>
                <TextBlock Text="{Binding Problem.NotificationDate, StringFormat='Дата обнаружения: dd.MM.yyyy'}" FontSize="11" 
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                <Border Background="{Binding Problem.StatusColor}" CornerRadius="10" Padding="6,2" Margin="0,10,0,0" 
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Problem.Status}" FontSize="10" Foreground="White"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Кнопки действий (только для оператора) -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,15" IsVisible="{Binding CanTakeAction}">
            <StackPanel Spacing="10">
                <TextBlock Text="Действия" Classes="h3" Margin="0,0,0,10"/>
                <Button Command="{Binding AssignInspectionCommand}" 
                        Background="{StaticResource WarningBrush}" Padding="15,8"
                        IsVisible="{Binding ShowAssignInspectionButton}">
                    Назначить проверку
                </Button>

                <!-- После получения ответа от инспектора -->
                <StackPanel IsVisible="{Binding ShowInspectionResponse}">
                    <TextBlock Text="{Binding InspectionResponseText}" FontSize="12" Foreground="{StaticResource WarningBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding MarkAsFalseCommand}" 
                                Background="{StaticResource DangerBrush}" Padding="15,8">Ложные показания</Button>
                        <Button Command="{Binding RequestRepairCommand}" 
                                Background="{StaticResource WarningBrush}" Padding="15,8">Требуется ремонт</Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- История изменений -->
        <Border Grid.Row="2" Classes="card">
            <StackPanel>
                <TextBlock Text="История изменений статуса" Classes="h3" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding StatusHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="5" Padding="8" Margin="0,0,0,3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="12" Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Command="{Binding CloseCommand}" Background="{StaticResource TextMutedBrush}" Padding="20,8">Закрыть</Button>
        </StackPanel>

    </Grid>
</Window>