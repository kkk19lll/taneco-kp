<Window
    x:Class="Taneco.Views.ProblemDetailsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Taneco.Converters"
    xmlns:vm="clr-namespace:Taneco.ViewModels"
    Title="Детали проблемы"
    Width="600"
    Height="650"
    x:DataType="vm:ProblemDetailsViewModel"
    CanResize="False"
    TransparencyLevelHint="AcrylicBlur"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Window.Resources>

    <Window.Styles>
        <!--  Общие стили карточек  -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="10"
                        OffsetX="0"
                        OffsetY="3"
                        Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Стили кнопок  -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentColorDark}" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#E53E3E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#C53030" />
        </Style>

        <Style Selector="Button.warning">
            <Setter Property="Background" Value="#ED8936" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.warning:pointerover">
            <Setter Property="Background" Value="#DD6B20" />
        </Style>

        <!--  Стили для текста  -->
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:ProblemDetailsViewModel />
    </Design.DataContext>

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto">

        <!--  Информация о проблеме  -->
        <Border Grid.Row="0" Classes="card">
            <StackPanel Spacing="12">
                <!--  Заголовок и статус  -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border
                        Width="3"
                        Background="{Binding Problem.Status, Converter={StaticResource StatusToColorConverter}}"
                        CornerRadius="2" />
                    <TextBlock Classes="title" Text="{Binding Problem.Type}" />
                </StackPanel>

                <!--  Трубопровод  -->
                <StackPanel>
                    <TextBlock Classes="label" Text="Трубопровод" />
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Problem.PipelineName}" />
                </StackPanel>

                <!--  Описание  -->
                <StackPanel>
                    <TextBlock Classes="label" Text="Описание проблемы" />
                    <Border
                        Padding="12"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        CornerRadius="8">
                        <TextBlock
                            LineHeight="20"
                            Text="{Binding Problem.Description}"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <!--  Показания  -->
                <StackPanel>
                    <TextBlock Classes="label" Text="Показания" />
                    <Border
                        Padding="15"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="*,*,*,*">
                            <TextBlock
                                Grid.Column="0"
                                FontSize="12"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Показание:" />
                            <TextBlock
                                Grid.Column="1"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AccentColor}"
                                Text="{Binding Problem.MeasuredValue}" />
                            <TextBlock
                                Grid.Column="2"
                                FontSize="12"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Порог:" />
                            <TextBlock
                                Grid.Column="3"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="#E53E3E"
                                Text="{Binding Problem.ThresholdValue}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!--  Дата  -->
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{Binding Problem.NotificationDate, StringFormat='Создано: dd.MM.yyyy HH:mm'}" />

                <!--  Бейдж статуса  -->
                <Border
                    Padding="8,4"
                    HorizontalAlignment="Left"
                    Background="{Binding Problem.Status, Converter={StaticResource StatusToColorConverter}}"
                    CornerRadius="6">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{Binding Problem.Status}" />
                </Border>
            </StackPanel>
        </Border>

        <!--  Назначение проверки (форма)  -->
        <Border
            Grid.Row="1"
            Classes="card"
            IsVisible="{Binding ShowInspectionForm}">
            <StackPanel Spacing="8">
                <TextBlock Classes="section-title" Text="Назначить проверку" />

                <TextBlock Classes="label" Text="Выберите инспектора" />
                <ComboBox
                    Margin="0,4,0,12"
                    ItemsSource="{Binding Inspectors}"
                    SelectedItem="{Binding SelectedInspector}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Classes="label" Text="Срочность" />
                <ComboBox Margin="0,4,0,12" SelectedItem="{Binding Urgency}">
                    <ComboBoxItem>Низкая</ComboBoxItem>
                    <ComboBoxItem>Средняя</ComboBoxItem>
                    <ComboBoxItem>Высокая</ComboBoxItem>
                    <ComboBoxItem>Критическая</ComboBoxItem>
                </ComboBox>

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button
                        Classes="primary"
                        Command="{Binding AssignInspectionCommand}"
                        IsEnabled="{Binding SelectedInspector}">
                        Отправить
                    </Button>
                    <Button Classes="secondary" Command="{Binding CancelCommand}">
                        Отмена
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Ожидание результата проверки  -->
        <Border
            Grid.Row="1"
            Classes="card"
            IsVisible="{Binding ShowInspectionResult}">
            <StackPanel Spacing="8">
                <TextBlock Classes="section-title" Text="Результат проверки" />

                <TextBlock Classes="label" Text="Проверка завершена. Укажите результат:" />

                <TextBox
                    Height="100"
                    Margin="0,4,0,12"
                    AcceptsReturn="True"
                    Text="{Binding InspectionResultDescription}"
                    Watermark="Добавьте описание результата проверки..." />

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button Classes="warning" Command="{Binding ConfirmFalseReadingCommand}">
                        Ложные показания
                    </Button>
                    <Button Classes="danger" Command="{Binding ConfirmRepairRequiredCommand}">
                        Требуется ремонт
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Выбор начальника ремонтной службы  -->
        <Border
            Grid.Row="1"
            Classes="card"
            IsVisible="{Binding ShowRepairManagerSelection}">
            <StackPanel Spacing="8">
                <TextBlock Classes="section-title" Text="Назначить ремонт" />

                <TextBlock Classes="label" Text="Выберите начальника ремонтной службы" />
                <ComboBox
                    Margin="0,4,0,12"
                    ItemsSource="{Binding RepairManagers}"
                    SelectedItem="{Binding SelectedRepairManager}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button
                        Classes="primary"
                        Command="{Binding SendToRepairManagerCommand}"
                        IsEnabled="{Binding SelectedRepairManager}">
                        Отправить
                    </Button>
                    <Button Classes="secondary" Command="{Binding CancelCommand}">
                        Отмена
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Кнопка для начала назначения проверки  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,20"
            HorizontalAlignment="Center"
            IsVisible="{Binding ShowStartButton}">
            <Button Classes="primary" Command="{Binding StartInspectionCommand}">
                Назначить проверку
            </Button>
        </StackPanel>

        <!--  Кнопка закрытия  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,0"
            HorizontalAlignment="Center">
            <Button Classes="secondary" Command="{Binding CancelCommand}">
                Закрыть
            </Button>
        </StackPanel>

    </Grid>
</Window>
