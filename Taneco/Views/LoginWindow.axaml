<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Taneco.ViewModels"
        x:Class="Taneco.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Авторизация - ТАНЕКО"
        Width="400" Height="450"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    
    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Height="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ТАНЕКО" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Система мониторинга" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Форма входа -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30,0">
            
            <TextBox Watermark="Логин" 
                     Text="{Binding Login}"
                     Margin="0,0,0,15"
                     Height="35"/>
            
            <TextBox Watermark="Пароль" 
                     Text="{Binding Password}"
                     PasswordChar="●"
                     Margin="0,0,0,20"
                     Height="35"/>
            
            <Button Content="ВОЙТИ"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Height="35"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"/>
            
            <Button Content="ОТМЕНА"
                    Command="{Binding CancelCommand}"
                    Background="Transparent"
                    Foreground="{StaticResource TextMutedBrush}"
                    Height="35"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"/>
            
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
            
            <ProgressBar IsIndeterminate="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         Height="3"
                         Margin="0,10,0,0"/>
        </StackPanel>
        
        <!-- Нижняя информация -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" Height="35">
            <TextBlock Text="АО «ТАНЕКО» 2026"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        
    </Grid>
</Window>