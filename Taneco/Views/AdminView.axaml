<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Taneco.ViewModels"
             x:Class="Taneco.Views.AdminView"
             x:DataType="vm:AdminViewModel">

    <StackPanel Margin="15">

        <TextBlock Text="⚙️ Администрирование" Classes="h1" Margin="0,0,0,15"/>

        <Border Classes="card" Margin="0,0,0,15">
            <StackPanel>
                <Button Command="{Binding CreateBackupCommand}" Margin="0,10,0,0">
                    Создать бэкап
                </Button>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>