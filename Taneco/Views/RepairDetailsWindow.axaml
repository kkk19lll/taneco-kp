<Window
    x:Class="Taneco.Views.RepairDetailsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Taneco.Converters"
    xmlns:vm="clr-namespace:Taneco.ViewModels"
    Title="Детали ремонта"
    Width="600"
    Height="700"
    MinWidth="500"
    MinHeight="600"
    x:DataType="vm:RepairDetailsViewModel"
    CanResize="True"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
        <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
    </Window.Resources>

    <Grid Margin="15" RowDefinitions="Auto,*,Auto">
        <!--  Шапка с информацией о ремонте  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,15"
            Classes="card">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,10"
                    Classes="h3"
                    Text="ИНФОРМАЦИЯ О РЕМОНТЕ" />

                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding Repair.ProblemDescription}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="12"
                    Foreground="{StaticResource TextDarkBrush}"
                    Text="{Binding Repair.ProblemType}" />

                <Grid
                    Margin="0,15,0,0"
                    ColumnDefinitions="Auto,*,Auto,*"
                    RowDefinitions="Auto,Auto,Auto">
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Оборудование:" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        FontSize="13"
                        FontWeight="Bold"
                        Text="{Binding Repair.EquipmentName}" />

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="15,0,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Бригада:" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="3"
                        Margin="5,0,0,0"
                        FontSize="13"
                        FontWeight="Bold"
                        Text="{Binding Repair.TeamName}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Бюджет:" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="5,10,0,0"
                        FontSize="13"
                        FontWeight="Bold"
                        Foreground="{StaticResource SuccessBrush}"
                        Text="{Binding Repair.Budget}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="15,10,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Дата начала:" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="3"
                        Margin="5,10,0,0"
                        FontSize="13"
                        Text="{Binding Repair.StartDate, StringFormat='dd.MM.yyyy'}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Дата окончания:" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="5,10,0,0"
                        FontSize="13"
                        Text="{Binding Repair.EndDate, StringFormat='dd.MM.yyyy'}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="2"
                        Margin="15,10,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Кто назначил:" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="3"
                        Margin="5,10,0,0"
                        FontSize="13"
                        Text="{Binding Repair.AssignedBy}" />
                </Grid>

                <Border
                    Margin="0,15,0,0"
                    Padding="8,4"
                    HorizontalAlignment="Left"
                    Background="{Binding Repair.StatusColor}"
                    CornerRadius="10">
                    <TextBlock
                        FontSize="11"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding Repair.Status}" />
                </Border>
            </StackPanel>
        </Border>

        <!--  Секция управления ремонтом  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,15"
            Classes="card"
            IsVisible="{Binding CanManage}">
            <ScrollViewer>
                <StackPanel Spacing="15">
                    <TextBlock
                        Margin="0,0,0,10"
                        Classes="h3"
                        Text="УПРАВЛЕНИЕ РЕМОНТОМ" />

                    <!--  Установка бюджета  -->
                    <Border Classes="inner-card">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Установка бюджета" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBox
                                    Width="180"
                                    Text="{Binding EditBudget}"
                                    Watermark="Сумма в рублях" />
                                <Button
                                    Padding="15,8"
                                    Background="{StaticResource SuccessBrush}"
                                    Command="{Binding SaveBudgetCommand}">
                                    Сохранить бюджет
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  Назначение бригады (только для статуса "Запланирован")  -->
                    <Border Classes="inner-card" IsVisible="{Binding CanAssignTeam}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Назначение бригады" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ComboBox
                                    Width="220"
                                    DisplayMemberBinding="{Binding Name}"
                                    ItemsSource="{Binding RepairTeams}"
                                    SelectedItem="{Binding SelectedTeam}" />
                                <Button
                                    Padding="15,8"
                                    Background="{StaticResource WarningBrush}"
                                    Command="{Binding AssignTeamCommand}">
                                    Назначить
                                </Button>
                                <Button
                                    Padding="15,8"
                                    Background="{StaticResource InfoBrush}"
                                    Command="{Binding DiagnoseTeamCommand}">
                                    Диагностика
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  Изменение статуса  -->
                    <Border Classes="inner-card" IsVisible="{Binding CanUpdateStatus}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Изменение статуса" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ComboBox
                                    Width="200"
                                    ItemsSource="{Binding AvailableStatuses}"
                                    SelectedItem="{Binding SelectedStatus}" />
                                <Button
                                    Padding="15,8"
                                    Background="{StaticResource InfoBrush}"
                                    Command="{Binding UpdateStatusCommand}">
                                    Изменить статус
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  Результаты проверки  -->
                    <Border Classes="inner-card" IsVisible="{Binding Repair.InspectionDescription, Converter={StaticResource StringToBoolConverter}}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                FontWeight="Bold"
                                Text="РЕЗУЛЬТАТЫ ПРОВЕРКИ" />
                            <TextBlock
                                FontSize="11"
                                Text="{Binding Repair.InspectionDescription}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--  Кнопки действий  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,15,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="15">
            <Button
                Padding="20,8"
                Background="{StaticResource InfoBrush}"
                Command="{Binding GenerateReportCommand}"
                IsVisible="{Binding IsRepairCompleted}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="Сформировать отчет" />
                </StackPanel>
            </Button>
            <Button
                Padding="20,8"
                Background="{StaticResource TextMutedBrush}"
                Command="{Binding CloseCommand}">
                Закрыть
            </Button>
        </StackPanel>
    </Grid>
</Window>
