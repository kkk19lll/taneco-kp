<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Taneco.ViewModels"
        x:Class="Taneco.Views.RepairDetailsWindow"
        x:DataType="vm:RepairDetailsViewModel"
        Title="Детали ремонта"
        Width="550" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid RowDefinitions="Auto,*,Auto" Margin="15">
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Информация о ремонте" Classes="h3" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Repair.ProblemDescription}" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="Auto,Auto" Margin="0,10,0,0">
                    <TextBlock Text="Бригада:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Repair.TeamName}" FontSize="13" FontWeight="Bold" Margin="10,0,0,0"/>
                </Grid>
                <Grid ColumnDefinitions="Auto,Auto" Margin="0,5,0,0">
                    <TextBlock Text="Бюджет:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Repair.Budget, StringFormat=\{0:C\}}" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}" Margin="10,0,0,0"/>
                </Grid>
                <TextBlock Text="{Binding Repair.StartDate, StringFormat=dd.MM.yyyy}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                <TextBlock Text="{Binding Repair.EndDate, StringFormat=dd.MM.yyyy}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                <Border Background="{Binding Repair.StatusColor}" CornerRadius="10" Padding="6,2" Margin="0,10,0,0"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Repair.Status}" FontSize="10" Foreground="White"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card" Margin="0,0,0,15" IsVisible="{Binding CanManage}">
            <StackPanel Spacing="10">
                <TextBlock Text="Управление ремонтом" Classes="h3" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Бюджет:" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding EditBudget}" Width="150"/>
                    <Button Command="{Binding SaveBudgetCommand}" Background="{StaticResource SuccessBrush}"
                            Padding="15,8">Сохранить</Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding CanAssignTeam}">
                    <TextBlock Text="Назначить бригаду:" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding RepairTeams}"
                              SelectedItem="{Binding SelectedTeam}"
                              DisplayMemberBinding="{Binding Name}"
                              Width="180"/>
                    <Button Command="{Binding AssignTeamCommand}" Background="{StaticResource WarningBrush}"
                            Padding="15,8">Назначить</Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Статус:" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableStatuses}"
                              SelectedItem="{Binding SelectedStatus}"
                              Width="160"/>
                    <Button Command="{Binding UpdateStatusCommand}" Background="{StaticResource InfoBrush}"
                            Padding="15,8">Обновить статус</Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Command="{Binding CloseCommand}" Background="{StaticResource TextMutedBrush}" Padding="20,8">Закрыть</Button>
        </StackPanel>
    </Grid>
</Window>