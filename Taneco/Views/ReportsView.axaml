<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Taneco.ViewModels"
             x:Class="Taneco.Views.ReportsView"
             x:DataType="vm:ReportsViewModel"
             x:CompileBindings="True">
    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock Text="Отчеты и аналитика" Classes="h1" Margin="0,0,0,15"/>

            <Border Classes="card" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Отчёт по оборудованию" Classes="h3" Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding Pipelines}"
                              SelectedItem="{Binding SelectedPipeline}"
                              DisplayMemberBinding="{Binding Name}"
                              Margin="0,0,0,10"/>
                    <Button Command="{Binding GeneratePipelineReportCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            HorizontalAlignment="Left"
                            Padding="15,8">Сформировать отчёт</Button>
                </StackPanel>
            </Border>

            <Border Classes="card" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Статистика по датчикам" Classes="h3" Margin="0,0,0,10"/>
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                        <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Margin="0,0,0,0"/>
                    </Grid>
                    <Button Command="{Binding GenerateSensorStatisticsCommand}"
                            IsEnabled="{Binding !IsLoading}"
                            HorizontalAlignment="Left"
                            Padding="15,8">Рассчитать</Button>
                </StackPanel>
            </Border>

            <Border Classes="card" IsVisible="{Binding HasResult}">
                <StackPanel>
                    <TextBlock Text="Результат" Classes="h3" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ReportResult}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <Button Command="{Binding ExportReportCommand}"
                            IsVisible="{Binding CanExport}"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Padding="15,8">Экспорт</Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>