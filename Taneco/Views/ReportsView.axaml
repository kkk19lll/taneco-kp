<UserControl
    x:Class="Taneco.Views.ReportsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Taneco.Converters"
    xmlns:vm="clr-namespace:Taneco.ViewModels"
    x:CompileBindings="True"
    x:DataType="vm:ReportsViewModel">

    <UserControl.Resources>
        <conv:DateMaskConverter x:Key="DateMaskConverter" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock
                Margin="0,0,0,15"
                Classes="h1"
                Text="Отчеты и аналитика" />

            <!--  Отчёт по оборудованию  -->
            <Border Margin="0,0,0,15" Classes="card">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        Classes="h3"
                        Text="Отчёт по оборудованию" />
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Выберите оборудование для получения полной информации" />
                    <ComboBox
                        Margin="0,0,0,10"
                        HorizontalAlignment="Stretch"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{Binding Sensors}"
                        SelectedItem="{Binding SelectedSensor}" />
                    <Button
                        Padding="15,8"
                        HorizontalAlignment="Left"
                        Command="{Binding GenerateEquipmentReportCommand}"
                        IsEnabled="{Binding !IsLoading}">
                        Сформировать отчёт
                    </Button>
                </StackPanel>
            </Border>

            <!--  Статистика по оборудованию  -->
            <Border Margin="0,0,0,15" Classes="card">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        Classes="h3"
                        Text="Статистика по оборудованию" />
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Выберите оборудование и период для расчёта статистики" />
                    <ComboBox
                        Margin="0,0,0,10"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{Binding Sensors}"
                        SelectedItem="{Binding SelectedSensor}" />

                    <!--  Поля ввода даты с маской  -->
                    <Grid Margin="0,0,0,10" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="11"
                                Text="Дата начала (дд.мм.гггг)" />
                            <TextBox
                                MaxLength="10"
                                Text="{Binding StartDateString, Mode=TwoWay}"
                                Watermark="дд.мм.гггг" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="11"
                                Text="Дата окончания (дд.мм.гггг)" />
                            <TextBox
                                MaxLength="10"
                                Text="{Binding EndDateString, Mode=TwoWay}"
                                Watermark="дд.мм.гггг" />
                        </StackPanel>
                    </Grid>

                    <Button
                        Padding="15,8"
                        HorizontalAlignment="Left"
                        Command="{Binding GenerateStatisticsCommand}"
                        IsEnabled="{Binding !IsLoading}">
                        Рассчитать
                    </Button>
                </StackPanel>
            </Border>

            <!--  Сводные отчёты  -->
            <Border Margin="0,0,0,15" Classes="card">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        Classes="h3"
                        Text="Сводные отчёты" />
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Формирование отчётов по всему оборудованию и проблемам" />

                    <Grid Margin="0,0,0,10" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="11"
                                Text="Дата начала (дд.мм.гггг)" />
                            <TextBox
                                MaxLength="10"
                                Text="{Binding StartDateString, Mode=TwoWay}"
                                Watermark="дд.мм.гггг" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="11"
                                Text="Дата окончания (дд.мм.гггг)" />
                            <TextBox
                                MaxLength="10"
                                Text="{Binding EndDateString, Mode=TwoWay}"
                                Watermark="дд.мм.гггг" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button
                            Padding="15,8"
                            Command="{Binding GenerateComprehensiveEquipmentReportCommand}"
                            IsEnabled="{Binding !IsLoading}">
                            Сводный по оборудованию
                        </Button>
                        <Button
                            Padding="15,8"
                            Command="{Binding GenerateComprehensiveProblemsReportCommand}"
                            IsEnabled="{Binding !IsLoading}">
                            Сводный по проблемам
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Результат  -->
            <Border Classes="card" IsVisible="{Binding HasResult}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        Classes="h3"
                        Text="Результат" />
                    <Border
                        Margin="0,0,0,10"
                        Padding="10"
                        Background="{StaticResource SecondaryBackgroundBrush}"
                        CornerRadius="5">
                        <ScrollViewer MaxHeight="400">
                            <TextBlock
                                FontFamily="Courier New"
                                FontSize="12"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding ReportResult}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                    <Button
                        Padding="15,8"
                        HorizontalAlignment="Left"
                        Command="{Binding ExportReportCommand}"
                        IsVisible="{Binding CanExport}">
                        Экспорт в PDF
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
