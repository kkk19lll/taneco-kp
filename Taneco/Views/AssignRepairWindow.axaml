<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Taneco.ViewModels"
        x:Class="Taneco.Views.AssignRepairWindow"
        x:DataType="vm:AssignRepairViewModel"
        Title="Назначение ремонта"
        Width="400" Height="350"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="15">

        <Border Grid.Row="0" Classes="card" Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <TextBlock Text="Выберите начальника ремонтной службы" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding RepairManagers}" 
                          SelectedItem="{Binding SelectedRepairManager}"
                          DisplayMemberBinding="{Binding FullName}"
                          Height="35"/>

                <TextBlock Text="Приоритет ремонта" FontWeight="Bold" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Priorities}" 
                          SelectedItem="{Binding SelectedPriority}"
                          Height="35"/>

                <TextBlock Text="Комментарий" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBox Text="{Binding Comment}" Height="80" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,0">
            <Button Command="{Binding AssignCommand}" 
                    IsEnabled="{Binding CanAssign}"
                    Background="{StaticResource SuccessBrush}" Padding="20,8">Отправить</Button>
            <Button Command="{Binding CloseCommand}" 
                    Background="{StaticResource TextMutedBrush}" Padding="20,8">Отмена</Button>
        </StackPanel>

    </Grid>
</Window>