<UserControl
    x:Class="Taneco.Views.MonitoringView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Taneco.Converters"
    xmlns:vm="clr-namespace:Taneco.ViewModels"
    x:CompileBindings="False"
    x:DataType="vm:MonitoringViewModel">

    <UserControl.Styles>
        <!--  Стили для карточек  -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="8"
                        OffsetX="0"
                        OffsetY="2"
                        Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Стиль для кнопок  -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentColorDark}" />
        </Style>

        <!--  Стиль для кликабельных элементов  -->
        <Style Selector="Button.clickable-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.clickable-item:pointerover Border">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <conv:DateMaskConverter x:Key="DateMaskConverter" />
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="20">

            <!--  Статус и прогресс  -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="{Binding StatusMessage}" />
                    <ProgressBar
                        Height="4"
                        CornerRadius="2"
                        IsIndeterminate="{Binding IsLoading}" />
                </StackPanel>
            </Border>

            <!--  Выбор даты  -->
            <Border Classes="card" IsVisible="{Binding CanSelectDate}">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Выберите дату" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox
                            Width="140"
                            Text="{Binding SelectedDateString, Mode=TwoWay}"
                            Watermark="ДД.ММ.ГГГГ" />
                        <Button Classes="primary" Command="{Binding RefreshCommand}">
                            Обновить
                        </Button>
                    </StackPanel>

                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="Формат: ДД.ММ.ГГГГ (например, 20.11.2026)" />
                </StackPanel>
            </Border>

            <!--  Заголовок показаний датчиков  -->
            <StackPanel
                Margin="0,8,0,12"
                Orientation="Horizontal"
                Spacing="8">
                <Border
                    Width="4"
                    Background="{DynamicResource AccentColor}"
                    CornerRadius="2" />
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Показания датчиков" />
            </StackPanel>

            <!--  Список показаний датчиков  -->
            <ItemsControl ItemsSource="{Binding Measurements}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            HorizontalAlignment="Stretch"
                            Classes="clickable-item"
                            Command="{Binding DataContext.MeasurementClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                            <Border
                                Margin="0,0,0,10"
                                Padding="16"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                CornerRadius="10">
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto">

                                    <!--  Основная информация  -->
                                    <StackPanel
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            Text="{Binding SensorName}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="{Binding PipelineName}" />
                                    </StackPanel>

                                    <!--  Значение и единица измерения  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="20,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                            Text="{Binding Value}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="{Binding Unit}" />
                                    </StackPanel>

                                    <!--  Статус-бейдж  -->
                                    <Border
                                        Grid.Column="2"
                                        Margin="15,0,0,0"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Status}" />
                                    </Border>

                                    <!--  Стрелка  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="›" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Итого показаний  -->
            <Border
                Margin="0,8,0,20"
                Padding="12"
                Background="{DynamicResource TertiaryBackgroundBrush}"
                CornerRadius="8">
                <TextBlock
                    FontSize="12"
                    FontWeight="Medium"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{Binding Measurements.Count, StringFormat='Всего показаний за выбранный день: {0}'}"
                    TextAlignment="Center" />
            </Border>

            <!--  Заголовок активных проблем  -->
            <StackPanel
                Margin="0,8,0,12"
                Orientation="Horizontal"
                Spacing="8">
                <Border
                    Width="4"
                    Background="{DynamicResource ErrorColor}"
                    CornerRadius="2" />
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Активные проблемы" />
            </StackPanel>

            <!--  Список активных проблем  -->
            <ItemsControl ItemsSource="{Binding ActiveProblems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            HorizontalAlignment="Stretch"
                            Classes="clickable-item"
                            Command="{Binding DataContext.ProblemClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                            <Border
                                Margin="0,0,0,10"
                                Padding="16"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Левая цветная полоска  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="5"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Stretch"
                                        Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                        CornerRadius="3" />

                                    <!--  Информация о проблеме  -->
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Text="{Binding PipelineName}" />
                                            <Border
                                                Padding="8,2"
                                                Background="{Binding RiskCategory, Converter={StaticResource StatusToBrushConverter}}"
                                                CornerRadius="6">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding Type}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="{Binding Description}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!--  Правая колонка с датой и статусом (фиксированная ширина 160)  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="15,0,0,0"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="{Binding NotificationDate, StringFormat=dd.MM.yyyy}"
                                            TextAlignment="Center" />

                                        <!--  Бейдж статуса с переносом текста  -->
                                        <Border
                                            Padding="8,6"
                                            Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                            CornerRadius="8">
                                            <TextBlock
                                                MaxWidth="140"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Status}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Итого проблем  -->
            <Border
                Margin="0,8,0,0"
                Padding="12"
                Background="{DynamicResource TertiaryBackgroundBrush}"
                CornerRadius="8">
                <TextBlock
                    FontSize="12"
                    FontWeight="Medium"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{Binding ActiveProblems.Count, StringFormat='Всего активных проблем за выбранный день: {0}'}"
                    TextAlignment="Center" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
