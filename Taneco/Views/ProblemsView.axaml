<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Taneco.ViewModels"
             x:Class="Taneco.Views.ProblemsView"
             x:DataType="vm:ProblemsViewModel">

    <ScrollViewer>
        <StackPanel Margin="15">

            <TextBlock Text="Управление проблемами" Classes="h1" Margin="0,0,0,15"/>

            <Border Classes="card" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding RefreshCommand}" Padding="15,8">Обновить</Button>
                    <Button Command="{Binding CreateProblemCommand}" IsVisible="{Binding CanCreateProblem}" Padding="15,8">Новая проблема</Button>

                    <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" Width="140"/>

                    <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <ComboBox ItemsSource="{Binding TypeFilters}" SelectedItem="{Binding SelectedTypeFilter}" Width="150"/>
                </StackPanel>
            </Border>

            <!-- Список проблем -->
            <ItemsControl ItemsSource="{Binding FilteredProblems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="card" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <Border Grid.Column="0" Background="{Binding StatusColor}" CornerRadius="5" Width="4" Height="30" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding PipelineName}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{StaticResource WarningBrush}" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding NotificationDate, StringFormat='dd.MM.yyyy'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding NotificationTime}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                    <Border Background="{Binding StatusColor}" CornerRadius="10" Padding="8,3" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding FilteredProblems.Count, StringFormat='Всего проблем: {0}'}"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>