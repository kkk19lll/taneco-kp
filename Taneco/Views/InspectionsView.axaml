<UserControl
    x:Class="Taneco.Views.InspectionsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Taneco.ViewModels"
    x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock
                Margin="0,0,0,15"
                Classes="h1"
                Text="Проверки" />

            <Border
                Margin="0,0,0,15"
                Padding="10"
                Classes="card">
                <StackPanel>
                    <Grid Margin="0,0,0,10" ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBox
                            Grid.Column="0"
                            MinWidth="180"
                            Text="{Binding SearchText}"
                            Watermark="Поиск..." />

                        <Button
                            Grid.Column="3"
                            Margin="5,0,0,0"
                            Padding="10,5"
                            Command="{Binding RefreshCommand}">
                            Обновить
                        </Button>
                    </Grid>

                    <WrapPanel>
                        <WrapPanel Margin="0,0,15,5">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="Статус:" />
                            <ComboBox
                                Width="120"
                                ItemsSource="{Binding StatusFilters}"
                                SelectedItem="{Binding SelectedStatusFilter}" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,15,5">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="Дата с:" />
                            <TextBox
                                Width="110"
                                MaxLength="10"
                                Text="{Binding FilterStartDateText, Mode=TwoWay}"
                                Watermark="ДД.ММ.ГГГГ" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,5">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Text="по:" />
                            <TextBox
                                Width="110"
                                MaxLength="10"
                                Text="{Binding FilterEndDateText, Mode=TwoWay}"
                                Watermark="ДД.ММ.ГГГГ" />
                        </WrapPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Button
                Margin="0,0,0,15"
                Padding="15,8"
                HorizontalAlignment="Left"
                Background="#2196F3"
                Command="{Binding GenerateReportCommand}"
                Foreground="White"
                IsVisible="{Binding IsAdmin}">
                Составить отчёт
            </Button>

            <ItemsControl ItemsSource="{Binding FilteredInspections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Classes="card">
                            <Button
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding $parent[ItemsControl].DataContext.InspectionClickCommand}"
                                CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Одна линия до информации с капсом - цветная -->
                                    <Border
                                        Grid.Column="0"
                                        Width="4"
                                        Height="40"
                                        Margin="0,0,10,0"
                                        Background="{Binding StatusColor}"
                                        CornerRadius="5" />
                                    
                                    <StackPanel Grid.Column="1">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding ProblemType}" />
                                        <TextBlock
                                            MaxHeight="40"
                                            FontSize="12"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Text="{Binding ProblemDescription}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{StaticResource TextDarkBrush}"
                                            Text="{Binding EmployeeName}" />
                                    </StackPanel>
                                    
                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Text="{Binding StartDate, StringFormat=dd.MM.yyyy}" />
                                        <!-- Статус цветной, а не серый -->
                                        <Border
                                            Margin="0,5,0,0"
                                            Padding="6,2"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="White"
                                                Text="{Binding Status}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Margin="0,10,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="{Binding FilteredInspections.Count, StringFormat='Всего проверок: {0}'}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>